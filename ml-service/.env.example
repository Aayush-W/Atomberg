# ML Service Deployment Environment Variables

# For HuggingFace Spaces deployment
# Set these in your HF Spaces secrets or environment

# Backend API (your HuggingFace backend)
BACKEND_URL=https://your-username-backend-repo.hf.space/api

# Frontend URL (after deploying to Vercel)
FRONTEND_URL=https://goalforge-yourname.vercel.app

# Optional: Model paths
MODELS_DIR=/app/models/saved

# Optional: Logging
LOG_LEVEL=INFO
