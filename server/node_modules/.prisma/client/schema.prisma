generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  EMPLOYEE
  MANAGER
  ADMIN
}

enum AuthProvider {
  LOCAL
  MICROSOFT_DEMO
}

enum UoMType {
  MIN
  MAX
  TIMELINE
  ZERO
}

enum GoalSensitivity {
  NORMAL
  TECHNICAL
  FINANCIAL
}

enum GoalStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  LOCKED
}

enum Quarter {
  Q1
  Q2
  Q3
  Q4
}

enum CheckInStatus {
  NOT_STARTED
  ON_TRACK
  COMPLETED
}

enum NotificationChannel {
  IN_APP
  EMAIL
  TEAMS
}

enum KudosBadgeType {
  COLLABORATOR
  PROBLEM_SOLVER
  INNOVATION_SPARK
  CUSTOMER_CHAMPION
  EXECUTION_ACE
}

enum GoalConflictSeverity {
  LOW
  MEDIUM
  HIGH
}

enum GoalConflictStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
}

enum EscalationPhase {
  NUDGE
  ESCALATED
}

model Tenant {
  id                String               @id @default(uuid())
  name              String
  slug              String               @unique
  webhookSecret     String
  branding          Json?
  users             User[]
  cycles            Cycle[]
  goals             Goal[]
  goalDependencies  GoalDependency[]
  checkIns          CheckIn[]
  auditLogs         AuditLog[]
  escalationRules   EscalationRule[]
  notifications     Notification[]
  delegations       ApprovalDelegation[]
  kudos             Kudos[]
  conflictAlerts    GoalConflictAlert[]
  escalationEvents  EscalationEvent[]
  domainEvents      DomainEvent[]
  webhookEndpoints  WebhookEndpoint[]
  webhookDeliveries WebhookDelivery[]
  apiKeys           ApiIdempotencyKey[]
  featureFlags      FeatureFlag[]
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
}

model User {
  id                  String               @id @default(uuid())
  tenantId            String
  tenant              Tenant               @relation(fields: [tenantId], references: [id])
  name                String
  email               String               @unique
  password            String
  role                Role
  department          String
  jobTitle            String?
  authProvider        AuthProvider         @default(LOCAL)
  microsoftEntraId    String?              @unique
  microsoftTenantId   String?
  managerId           String?
  manager             User?                @relation("Reports", fields: [managerId], references: [id])
  reportees           User[]               @relation("Reports")
  goals               Goal[]
  checkIns            CheckIn[]
  auditLogs           AuditLog[]
  notifications       Notification[]
  kudosSent           Kudos[]              @relation("KudosSent")
  kudosReceived       Kudos[]              @relation("KudosReceived")
  delegationsGiven    ApprovalDelegation[] @relation("DelegationDelegator")
  delegationsReceived ApprovalDelegation[] @relation("DelegationDelegate")
  escalationEvents    EscalationEvent[]    @relation("EscalationEventRecipient")
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@index([tenantId, role, managerId])
}

model Cycle {
  id               String              @id @default(uuid())
  tenantId         String
  tenant           Tenant              @relation(fields: [tenantId], references: [id])
  name             String
  startDate        DateTime
  endDate          DateTime
  isActive         Boolean             @default(true)
  goalSettingOpen  DateTime
  q1Open           DateTime
  q2Open           DateTime
  q3Open           DateTime
  q4Open           DateTime
  bypassWindow     Boolean             @default(false)
  goals            Goal[]
  conflictAlerts   GoalConflictAlert[]
  escalationEvents EscalationEvent[]
  createdAt        DateTime            @default(now())

  @@index([tenantId, isActive, startDate])
}

model Goal {
  id              String              @id @default(uuid())
  tenantId        String
  tenant          Tenant              @relation(fields: [tenantId], references: [id])
  userId          String
  user            User                @relation(fields: [userId], references: [id])
  cycleId         String
  cycle           Cycle               @relation(fields: [cycleId], references: [id])
  thrustArea      String
  title           String
  description     String
  uomType         UoMType
  target          Float
  targetDate      DateTime?
  weightage       Float
  sensitivity     GoalSensitivity     @default(NORMAL)
  status          GoalStatus          @default(DRAFT)
  isShared        Boolean             @default(false)
  parentGoalId    String?
  parentGoal      Goal?               @relation("SharedGoals", fields: [parentGoalId], references: [id])
  sharedWith      Goal[]              @relation("SharedGoals")
  qualityScore    Float?
  qualityFeedback Json?
  checkIns        CheckIn[]
  auditLogs       AuditLog[]
  kudos           Kudos[]
  conflictAlertsA GoalConflictAlert[] @relation("GoalConflictA")
  conflictAlertsB GoalConflictAlert[] @relation("GoalConflictB")
  dependencies    GoalDependency[]    @relation("DependentGoal")
  dependents      GoalDependency[]    @relation("RequiredGoal")
  managerComment  String?
  lockedAt        DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([tenantId, userId, cycleId, status])
}

model GoalDependency {
  tenantId        String
  tenant          Tenant @relation(fields: [tenantId], references: [id])
  id              String @id @default(uuid())
  dependentGoalId String
  requiredGoalId  String
  dependentGoal   Goal   @relation("DependentGoal", fields: [dependentGoalId], references: [id])
  requiredGoal    Goal   @relation("RequiredGoal", fields: [requiredGoalId], references: [id])

  @@index([tenantId, dependentGoalId, requiredGoalId])
}

model CheckIn {
  tenantId         String
  tenant           Tenant        @relation(fields: [tenantId], references: [id])
  id               String        @id @default(uuid())
  goalId           String
  goal             Goal          @relation(fields: [goalId], references: [id])
  userId           String
  user             User          @relation(fields: [userId], references: [id])
  quarter          Quarter
  actualValue      Float
  completionDate   DateTime?
  status           CheckInStatus
  progressScore    Float
  employeeNote     String?
  managerComment   String?
  managerCheckedAt DateTime?
  sentiment        Float?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([tenantId, userId, quarter])
}

model AuditLog {
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  id        String   @id @default(uuid())
  goalId    String?
  goal      Goal?    @relation(fields: [goalId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String
  field     String?
  oldValue  String?
  newValue  String?
  timestamp DateTime @default(now())

  @@index([tenantId, userId, timestamp])
}

model EscalationRule {
  tenantId        String
  tenant          Tenant            @relation(fields: [tenantId], references: [id])
  id              String            @id @default(uuid())
  name            String
  triggerType     String
  daysThreshold   Int
  isActive        Boolean           @default(true)
  escalationChain Json
  events          EscalationEvent[]

  @@index([tenantId, isActive, triggerType])
}

model Notification {
  tenantId  String
  tenant    Tenant              @relation(fields: [tenantId], references: [id])
  id        String              @id @default(uuid())
  userId    String
  user      User                @relation(fields: [userId], references: [id])
  type      String
  channel   NotificationChannel @default(IN_APP)
  title     String
  message   String
  metadata  Json?
  isRead    Boolean             @default(false)
  createdAt DateTime            @default(now())

  @@index([tenantId, userId, createdAt])
}

model ApprovalDelegation {
  tenantId           String
  tenant             Tenant   @relation(fields: [tenantId], references: [id])
  id                 String   @id @default(uuid())
  delegatorManagerId String
  delegateManagerId  String
  delegatorManager   User     @relation("DelegationDelegator", fields: [delegatorManagerId], references: [id])
  delegateManager    User     @relation("DelegationDelegate", fields: [delegateManagerId], references: [id])
  startsAt           DateTime
  endsAt             DateTime
  reason             String
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([tenantId, delegatorManagerId, delegateManagerId])
}

model Kudos {
  tenantId   String
  tenant     Tenant         @relation(fields: [tenantId], references: [id])
  id         String         @id @default(uuid())
  senderId   String
  receiverId String
  goalId     String?
  sender     User           @relation("KudosSent", fields: [senderId], references: [id])
  receiver   User           @relation("KudosReceived", fields: [receiverId], references: [id])
  goal       Goal?          @relation(fields: [goalId], references: [id])
  badgeType  KudosBadgeType
  note       String
  createdAt  DateTime       @default(now())

  @@index([tenantId, receiverId, createdAt])
}

model GoalConflictAlert {
  tenantId   String
  tenant     Tenant               @relation(fields: [tenantId], references: [id])
  id         String               @id @default(uuid())
  goalAId    String
  goalBId    String
  cycleId    String
  department String
  severity   GoalConflictSeverity
  reason     String
  status     GoalConflictStatus   @default(OPEN)
  detectedAt DateTime             @default(now())
  goalA      Goal                 @relation("GoalConflictA", fields: [goalAId], references: [id])
  goalB      Goal                 @relation("GoalConflictB", fields: [goalBId], references: [id])
  cycle      Cycle                @relation(fields: [cycleId], references: [id])

  @@index([tenantId, cycleId, department])
}

model EscalationEvent {
  tenantId        String
  tenant          Tenant          @relation(fields: [tenantId], references: [id])
  id              String          @id @default(uuid())
  uniqueKey       String          @unique
  ruleId          String
  recipientUserId String
  cycleId         String?
  quarter         Quarter?
  triggerType     String
  phase           EscalationPhase
  message         String
  metadata        Json?
  createdAt       DateTime        @default(now())
  rule            EscalationRule  @relation(fields: [ruleId], references: [id])
  recipientUser   User            @relation("EscalationEventRecipient", fields: [recipientUserId], references: [id])
  cycle           Cycle?          @relation(fields: [cycleId], references: [id])

  @@index([tenantId, recipientUserId, createdAt])
}

model DomainEvent {
  tenantId      String
  tenant        Tenant    @relation(fields: [tenantId], references: [id])
  id            String    @id @default(uuid())
  aggregateType String
  aggregateId   String
  eventName     String
  payload       Json
  correlationId String?
  status        String    @default("PENDING")
  publishedAt   DateTime?
  createdAt     DateTime  @default(now())

  @@index([tenantId, eventName, createdAt])
}

model WebhookEndpoint {
  tenantId         String
  tenant           Tenant            @relation(fields: [tenantId], references: [id])
  id               String            @id @default(uuid())
  name             String
  url              String
  secret           String
  subscribedEvents Json
  isActive         Boolean           @default(true)
  failureCount     Int               @default(0)
  lastDeliveredAt  DateTime?
  createdByUserId  String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  deliveries       WebhookDelivery[]

  @@index([tenantId, isActive, createdAt])
}

model WebhookDelivery {
  tenantId     String
  tenant       Tenant          @relation(fields: [tenantId], references: [id])
  id           String          @id @default(uuid())
  endpointId   String
  eventId      String
  eventName    String
  status       String          @default("PENDING")
  statusCode   Int?
  requestBody  Json
  responseBody String?
  attemptCount Int             @default(0)
  nextRetryAt  DateTime?
  deliveredAt  DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  endpoint     WebhookEndpoint @relation(fields: [endpointId], references: [id])

  @@index([tenantId, status, createdAt])
}

model ApiIdempotencyKey {
  tenantId         String
  tenant           Tenant   @relation(fields: [tenantId], references: [id])
  id               String   @id @default(uuid())
  idempotencyKey   String
  routeFingerprint String
  statusCode       Int
  responseBody     Json
  createdAt        DateTime @default(now())
  expiresAt        DateTime

  @@unique([tenantId, idempotencyKey, routeFingerprint])
  @@index([tenantId, expiresAt])
}

model FeatureFlag {
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  id          String   @id @default(uuid())
  key         String
  description String?
  enabled     Boolean  @default(false)
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, key])
  @@index([tenantId, updatedAt])
}
