# Frontend Deployment Environment Variables

# Backend API URL (hosted on HuggingFace)
VITE_API_URL=https://your-username-backend-repo.hf.space/api

# ML Service URL (hosted on HuggingFace Spaces)
VITE_ML_API_URL=https://your-username-goalforge-ml.hf.space

# App name/branding
VITE_APP_NAME=GoalForge

# Note: These variables will be set in Vercel dashboard during deployment
